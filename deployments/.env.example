# deployments/.env.example
# Docker Compose 环境变量模板
# 复制为 .env 并修改密码:  cp .env.example .env

# -- PostgreSQL ------------------------------------------------
POSTGRES_USER=hanfledge
POSTGRES_PASSWORD=hanfledge_secret   # ⚠️ 生产环境请修改
POSTGRES_DB=hanfledge
POSTGRES_PORT=5433

# -- Neo4j -----------------------------------------------------
NEO4J_PASSWORD=neo4j_secret          # ⚠️ 生产环境请修改
NEO4J_HTTP_PORT=7475
NEO4J_BOLT_PORT=7688

# -- Redis -----------------------------------------------------
REDIS_PORT=6381
