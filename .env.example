# =========================
# Hanfledge - Environment Configuration
# =========================

# Server
SERVER_PORT=8080
GIN_MODE=debug  # debug | release
CORS_ORIGINS=http://localhost:3000  # Comma-separated; use * for dev only

# PostgreSQL (with pgvector)
DB_HOST=localhost
DB_PORT=5433
DB_USER=hanfledge
DB_PASSWORD=hanfledge_secret
DB_NAME=hanfledge
DB_SSLMODE=disable

# Neo4j
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# Redis
REDIS_URL=redis://localhost:6381/0

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY_HOURS=24

# LLM Provider: ollama | dashscope | gemini
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# DashScope (Qwen Cloud)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max

# Embedding
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3

# WeKnora Knowledge Base Service
WEKNORA_ENABLED=false
WEKNORA_BASE_URL=http://localhost:9380/api/v1
WEKNORA_API_KEY=
